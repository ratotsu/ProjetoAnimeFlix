@app.route("/")
def index():
    return send_from_directory("static", "index.html")

@app.route("/api/health")
def health_check():
    """Health check básico."""
    return jsonify({
        "status": "healthy",
        "environment": ENVIRONMENT,
        "https": request.is_secure or request.headers.get("X-Forwarded-Proto") == "https",
        "timestamp": datetime.utcnow().isoformat()
    })

@app.route("/api/health/detailed")
def health_detailed():
    """Health check detalhado."""
    db_status = "ok"
    try:
        db.session.execute(db.text("SELECT 1"))
    except Exception as e:
        db_status = f"error: {str(e)}"
    
    return jsonify({
        "status": "healthy" if db_status == "ok" else "degraded",
        "database": db_status,
        "environment": ENVIRONMENT,
        "https": request.is_secure or request.headers.get("X-Forwarded-Proto") == "https",
        "timestamp": datetime.utcnow().isoformat(),
        "version": "2.0.0"
    })

# ============================================
# ROTAS DE AUTENTICAÇÃO JWT
# ============================================

@app.route("/api/auth/login", methods=["POST"])
@limiter.limit("5 per minute")
def login():
    """
    Login com credenciais.
    Retorna access_token (15 min) e refresh_token (30 dias).
    Aceita credenciais via JSON body ou Basic Auth header.
    """
    dados = request.get_json() or {}
    auth_header = request.headers.get("Authorization", "")
    
    username = ""
    password = ""
    
    # Aceitar credenciais via JSON
    if "username" in dados and "password" in dados:
        username = dados.get("username", "").strip()
        password = dados.get("password", "")
    # Aceitar via Basic Auth header (backward compatibility)
    elif auth_header.lower().startswith("basic "):
        import base64
        try:
            decoded = base64.b64decode(auth_header.split(None, 1)[1]).decode("utf-8")
            username, password = decoded.split(":", 1)
        except Exception:
            return jsonify({"erro": "Formato de autorização inválido"}), 400
    else:
        return jsonify({"erro": "Credenciais necessárias (JSON ou Basic Auth)"}), 400
    
    if not username or not password:
        return jsonify({"erro": "Usuário e senha são obrigatórios"}), 400
    
    # Verificar credenciais
    user = User.query.filter_by(username=username).first()
    if not user or not user.check_password(password):
        app.logger.warning(f"Tentativa de login falhou para: {username} de {request.remote_addr}")
        return jsonify({"erro": "Credenciais inválidas"}), 401
    
    # Criar tokens
    additional_claims = {"role": user.role, "username": user.username}
    access_token = create_access_token(
        identity=user.id, 
        additional_claims=additional_claims
    )
    refresh_token = create_refresh_token(
        identity=user.id,
        additional_claims=additional_claims
    )
    
    # Armazenar refresh token no banco
    decoded_refresh = decode_token(refresh_token)
    
    db_token = RefreshToken(
        jti=decoded_refresh["jti"],
        user_id=user.id,
        token_hash=hash_token(refresh_token),
        expires_at=datetime.fromtimestamp(decoded_refresh["exp"]),
        ip_address=request.remote_addr,
        user_agent=request.headers.get("User-Agent", "")[:255]
    )
    db.session.add(db_token)
    
    # Limpar tokens expirados e limitar sessões
    cleanup_expired_tokens()
    limit_user_sessions(user.id)
    db.session.commit()
    
    app.logger.info(f"Login bem-sucedido: {username} de {request.remote_addr}")
    
    return jsonify({
        "user": user.to_dict(),
        "access_token": access_token,
        "refresh_token": refresh_token,
        "token_type": "Bearer",
        "expires_in": int(ACCESS_TOKEN_EXPIRES.total_seconds())
    }), 200

@app.route("/api/auth/refresh", methods=["POST"])
@limiter.limit("30 per hour")
@jwt_required(refresh=True)
def refresh():
    """Renova o access token usando refresh token válido."""
    current_user_id = get_jwt_identity()
    jwt_data = get_jwt()
    jti = jwt_data["jti"]
    
    # Verificar se refresh token é válido no banco
    db_token = RefreshToken.query.filter_by(jti=jti, revoked=False).first()
    if not db_token or not db_token.is_valid:
        return jsonify({"erro": "Refresh token inválido ou expirado"}), 401
    
    user = User.query.get(current_user_id)
    if not user:
        return jsonify({"erro": "Usuário não encontrado"}), 401
    
    # Criar novo access token
    additional_claims = {"role": user.role, "username": user.username}
    new_access_token = create_access_token(
        identity=user.id,
        additional_claims=additional_claims
    )
    
    return jsonify({
        "access_token": new_access_token,
        "token_type": "Bearer",
        "expires_in": int(ACCESS_TOKEN_EXPIRES.total_seconds())
    }), 200

@app.route("/api/auth/logout", methods=["POST"])
@jwt_required()
def logout():
    """Revoga o access token atual (logout)."""
    jwt_data = get_jwt()
    jti = jwt_data["jti"]
    user_id = get_jwt_identity()
    
    # Adicionar token à blacklist
    blacklisted = BlacklistedToken(
        jti=jti,
        token_type="access",
        user_id=user_id,
        expires_at=datetime.fromtimestamp(jwt_data["exp"])
    )
    db.session.add(blacklisted)
    db.session.commit()
    
    user =